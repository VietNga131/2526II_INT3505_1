{
  "info": {
    "name": "Flask-Book-API-Completed",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Get all books",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Response is array\", function () { const res = pm.response.json(); pm.expect(res.success).to.be.true; pm.expect(res.data).to.be.an('array'); });",
              "pm.test(\"Response time < 300ms\", function () { pm.expect(pm.response.responseTime).to.be.below(300); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/books"
      }
    },
    {
      "name": "2. Add new book (POST)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () { pm.response.to.have.status(201); });",
              "pm.test(\"Book created\", function () { const res = pm.response.json(); pm.expect(res.success).to.be.true; pm.collectionVariables.set(\"newBookId\", res.data.id); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Sách QA Testing\",\n  \"author\": \"Newman\"\n}" },
        "url": "{{baseUrl}}/books"
      }
    },
    {
      "name": "3. Get specific book by ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"ID matches\", function () { const res = pm.response.json(); pm.expect(res.data.id).to.eql(Number(pm.collectionVariables.get(\"newBookId\"))); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/books/{{newBookId}}"
      }
    },
    {
      "name": "4. Update book (PUT)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Title updated\", function () { const res = pm.response.json(); pm.expect(res.data.title).to.eql(\"Sách QA Testing - Version 2\"); });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{\n  \"title\": \"Sách QA Testing - Version 2\"\n}" },
        "url": "{{baseUrl}}/books/{{newBookId}}"
      }
    },
    {
      "name": "5. Delete book (DELETE)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () { pm.response.to.have.status(200); });",
              "pm.test(\"Deleted successfully\", function () { const res = pm.response.json(); pm.expect(res.success).to.be.true; });"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "url": "{{baseUrl}}/books/{{newBookId}}"
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://127.0.0.1:5000",
      "type": "string"
    },
    {
      "key": "newBookId",
      "value": "",
      "type": "string"
    }
  ]
}